<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net8.0-windows</TargetFramework>
		<UseWPF>true</UseWPF>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<RootNamespace>LocalWealthTracker</RootNamespace>

		<!-- Version — bump this before each release -->
		<Version>1.0.4</Version>
		<AssemblyVersion>1.0.4</AssemblyVersion>
		<FileVersion>1.0.4</FileVersion>

		<!-- App metadata -->
		<AssemblyTitle>Local Wealth Tracker</AssemblyTitle>
		<Description>Path of Exile wealth tracker using poe.ninja prices</Description>
		<Company>LocalWealthTracker</Company>
		<Product>LocalWealthTracker</Product>
		<ApplicationIcon>Resources\Wealth.ico</ApplicationIcon>
	</PropertyGroup>
	<ItemGroup>
		<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
		<PackageReference Include="LiveChartsCore.SkiaSharpView.WPF" Version="2.0.0-rc3.3" />
	</ItemGroup>
	<ItemGroup>
	  <None Include=".github\workflows\release.yml" />
	</ItemGroup>
</Project>