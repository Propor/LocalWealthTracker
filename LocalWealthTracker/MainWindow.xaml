<Window x:Class="LocalWealthTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:LocalWealthTracker.Converters"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Local Wealth Tracker — Path of Exile"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        Background="#09090b" Foreground="#f4f4f5">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="5"
                      GlassFrameThickness="0" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a1a1aa"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#27272a"/>
                                <Setter Property="Foreground" Value="#f4f4f5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#3f3f46"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a1a1aa"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#c0392b"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#922b21"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <converters:UrlToImageConverter x:Key="UrlToImage"/>
        <converters:SparklineToPointsConverter x:Key="SparklineToPoints"/>
        <converters:ColorToBrushConverter x:Key="ColorToBrush"/>
        <converters:EqualityConverter x:Key="Equality"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#f4f4f5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#27272a"/>
            <Setter Property="Foreground" Value="#f4f4f5"/>
            <Setter Property="BorderBrush" Value="#3f3f46"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3f3f46"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Delete ✕ button -->
        <Style x:Key="DeleteXButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#dc2626"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#f87171"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#18181b"/>
            <Setter Property="Foreground" Value="#f4f4f5"/>
            <Setter Property="BorderBrush" Value="#27272a"/>
            <Setter Property="RowBackground" Value="#18181b"/>
            <Setter Property="AlternatingRowBackground" Value="#1f1f23"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#27272a"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#27272a"/>
            <Setter Property="Foreground" Value="#d4d4d8"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#3f3f46"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#f4f4f5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="6,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#27272a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="36"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#18181b"/>
            <Setter Property="BorderBrush" Value="#27272a"/>
            <Setter Property="Foreground" Value="#f4f4f5"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#27272a"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3f3f46"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Focusable="False" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder" Background="#3f3f46" CornerRadius="3" Margin="1,0"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#52525b"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#71717a"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Focusable="False" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="6"/>
                    <Setter Property="MinHeight" Value="6"/>
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Border Background="Transparent">
                                    <Track x:Name="PART_Track">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageLeftCommand" Focusable="False" Opacity="0"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border x:Name="ThumbBorder" Background="#3f3f46" CornerRadius="3" Margin="0,1"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ThumbBorder" Property="Background" Value="#52525b"/>
                                                            </Trigger>
                                                            <Trigger Property="IsDragging" Value="True">
                                                                <Setter TargetName="ThumbBorder" Property="Background" Value="#71717a"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageRightCommand" Focusable="False" Opacity="0"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <!-- Title bar -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Update banner -->
            <RowDefinition Height="Auto"/>
            <!-- Summary -->
            <RowDefinition Height="200"/>
            <!-- Chart banner -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Status -->
        </Grid.RowDefinitions>

        <!-- ═══ Row 0 — Title bar ═══ -->
        <Border Background="#111113">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="─" Style="{StaticResource TitleBarButton}"
                            Click="MinimizeButton_Click" ToolTip="Minimize"/>
                    <Button Content="□"
                            Style="{StaticResource TitleBarButton}"
                            Click="MaximizeButton_Click" ToolTip="Maximize"/>
                    <Button Content="✕" Style="{StaticResource TitleBarCloseButton}"
                            Click="CloseButton_Click" ToolTip="Close"/>
                </StackPanel>
                <TextBlock Text="Local Wealth Tracker" VerticalAlignment="Center"
                           Margin="12,0" FontSize="12" Foreground="#52525b"/>
            </DockPanel>
        </Border>

        <!-- ═══ Row 1 — Toolbar ═══ -->
        <Border Grid.Row="1" Background="#18181b" Padding="12,8"
                BorderBrush="#27272a" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
<Button Content="🔄 Refresh" Command="{Binding RefreshCommand}"
                            FontSize="14" Margin="0,0,6,0"
                            ToolTip="Fetch stash items and update prices"/>
                    <Button Content="⏹ Cancel" Command="{Binding RefreshCancelCommand}"
                            FontSize="14" Margin="0,0,12,0"/>
                    <Button Content="⚙ Settings" Command="{Binding OpenSettingsCommand}"
                            FontSize="14"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontSize="13" Foreground="#71717a" Margin="0,0,16,0">
                        <Run Text="League: "/>
                        <Run Text="{Binding LeagueDisplay}" Foreground="#d4d4d8"
                             FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Foreground="#71717a" Margin="0,0,16,0">
                        <Run Text="Synced tabs: "/>
                        <Run Text="{Binding SyncedTabCount}" Foreground="#d4d4d8"
                             FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Foreground="#52525b"
                               ToolTip="Items in your stash that couldn't be matched to a poe.ninja price">
                        <Run Text="Unpriced: "/>
                        <Run Text="{Binding UnpricedCount}" Foreground="#71717a"/>
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ Row 2 — Update Banner (only visible when update available) ═══ -->
        <Border Grid.Row="2" Padding="12,8"
        Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#052e16"/>
                    <Setter Property="BorderBrush" Value="#22c55e"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsUpdating}" Value="True">
                            <Setter Property="Background" Value="#1c1917"/>
                            <Setter Property="BorderBrush" Value="#f59e0b"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <DockPanel>
                <!-- Buttons (right side) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                    VerticalAlignment="Center">

                    <!-- Progress bar (visible during download) -->
                    <ProgressBar Value="{Binding UpdateProgress}"
                         Maximum="100" Width="120" Height="14"
                         Background="#27272a" Foreground="#22c55e"
                         Margin="0,0,8,0"
                         Visibility="{Binding IsUpdating, Converter={StaticResource BoolToVis}}"/>

                    <!-- Download status text -->
                    <TextBlock Text="{Binding UpdateProgressText}"
                       FontSize="11" Foreground="#71717a"
                       VerticalAlignment="Center" Margin="0,0,12,0"
                       Visibility="{Binding IsUpdating, Converter={StaticResource BoolToVis}}"/>

                    <!-- Release notes link -->
                    <Button Content="📋 Notes" Command="{Binding OpenReleasePageCommand}"
                    Padding="10,4" FontSize="12" Margin="0,0,6,0"
                    Visibility="{Binding IsUpdating, 
                        Converter={StaticResource BoolToVis},
                        ConverterParameter=Invert}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUpdating}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Update button -->
                    <Button Command="{Binding InstallUpdateCommand}"
                    Padding="12,4" FontSize="12" Margin="0,0,6,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Content" Value="⬇ Update"/>
                                <Setter Property="Background" Value="#14532d"/>
                                <Setter Property="BorderBrush" Value="#22c55e"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUpdating}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Content" Value="Updating…"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Dismiss -->
                    <Button Content="✕" Command="{Binding DismissUpdateCommand}"
                    Padding="6,4" FontSize="12">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground" Value="#52525b"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUpdating}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Update text (left side) -->
                <TextBlock VerticalAlignment="Center" FontSize="13">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#22c55e"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUpdating}" Value="True">
                                    <Setter Property="Foreground" Value="#f59e0b"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
            <Run Text="🔔 " FontSize="14"/>
            <Run Text="{Binding UpdateText}"/>
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- ═══ Row 3 — Summary ═══ -->
        <Border Grid.Row="3" Background="#1f1f23" Padding="16,8"
                BorderBrush="#27272a" BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- Right: goal progress bar -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding HasGoal, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding GoalText}" FontSize="11" Foreground="#71717a"
                               VerticalAlignment="Center" Margin="0,0,8,0"
                               ToolTip="Progress towards your divine goal"/>
                    <ProgressBar Value="{Binding GoalProgress}" Maximum="100"
                                 Width="120" Height="6"
                                 Background="#27272a" Foreground="#f59e0b"
                                 VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="#b45309"
                               Margin="0,0,24,0" VerticalAlignment="Center"
                               ToolTip="Total wealth across all synced tabs">
                        <Run Text="{Binding TotalDivine, StringFormat='{}{0:N1}'}"/>
                        <Run Text=" divine" FontSize="14" Foreground="#b45309"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Foreground="#71717a" Margin="0,0,24,0"
                               VerticalAlignment="Center"
                               ToolTip="Current divine/chaos exchange rate from poe.ninja">
                        <Run Text="1 Divine = "/>
                        <Run Text="{Binding DivinePrice, StringFormat='{}{0:N0}'}"/>
                        <Run Text="c"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Foreground="#71717a" Margin="0,0,24,0"
                               VerticalAlignment="Center"
                               ToolTip="Time of last successful refresh">
                        <Run Text="Last: "/>
                        <Run Text="{Binding LastRefresh}"/>
                    </TextBlock>
                    <!-- Session profit -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                Visibility="{Binding HasSessionProfit, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding SessionProfitText}" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,6,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#4ade80"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSessionPositive}" Value="False">
                                            <Setter Property="Foreground" Value="#ef4444"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Content="↺" Command="{Binding ResetSessionCommand}"
                                Padding="4,1" FontSize="11"
                                ToolTip="Reset session baseline to current wealth"
                                Background="Transparent" BorderThickness="0" Foreground="#52525b"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ Row 4 — Wealth Chart Banner ═══ -->
        <Border Grid.Row="4" Background="#18181b" Padding="12,8"
                BorderBrush="#27272a" BorderThickness="0,0,0,1">
            <lvc:CartesianChart
                Series="{Binding ChartSeries}"
                XAxes="{Binding ChartXAxes}"
                YAxes="{Binding ChartYAxes}"
                TooltipPosition="Top"
                LegendPosition="Hidden"
                TooltipBackgroundPaint="{Binding ChartTooltipBackground}"
                TooltipTextPaint="{Binding ChartTooltipText}"
                AnimationsSpeed="00:00:00.300"/>
        </Border>

        <!-- ═══ Row 5 — Main content ═══ -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="300" MinWidth="250"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Stash tabs + Unpriced -->
            <DockPanel Margin="4">
                <TextBlock DockPanel.Dock="Top" Text="STASH TABS"
               FontWeight="Bold" FontSize="12" Foreground="#71717a"
               Margin="6,6,0,6"/>

                <!-- Unpriced items button — only visible when there are unpriced items -->
                <Border DockPanel.Dock="Bottom"
            Margin="0,4,0,0"
            Visibility="{Binding ShowUnpricedTab, Converter={StaticResource BoolToVis}}">
                    <Button Command="{Binding ShowUnpricedCommand}"
                HorizontalContentAlignment="Stretch"
                Padding="8,6">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#18080e" BorderBrush="#4a1d4a"
                            BorderThickness="1" CornerRadius="4"
                            Padding="8,6" Cursor="Hand">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding UnpricedCount}"
                                       Foreground="#ef4444" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        <StackPanel>
                                            <TextBlock Text="⚠ Unpriced Items" FontWeight="SemiBold"
                                           Foreground="#ef4444"
                                           TextTrimming="CharacterEllipsis"/>
                                            <TextBlock FontSize="11" Foreground="#78524e"
                                           TextTrimming="CharacterEllipsis">
                                    <Run Text="Items not found on poe.ninja"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>

                <ListBox x:Name="TabsList"
                         ItemsSource="{Binding Tabs}"
                         SelectedItem="{Binding SelectedTab}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         AllowDrop="True"
                         PreviewMouseLeftButtonDown="TabsList_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="TabsList_PreviewMouseMove"
                         DragOver="TabsList_DragOver"
                         Drop="TabsList_Drop">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="-8,-6,-8,-6" Padding="8,6"
                                    BorderThickness="3,0,0,0"
                                    BorderBrush="{Binding Color, Converter={StaticResource ColorToBrush}}">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding TotalDivine, StringFormat='{}{0:N1}d'}"
                                               Foreground="#f59e0b" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Summary}" FontSize="11"
                                                   Foreground="#71717a"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" Background="#27272a"/>

            <!-- Center: Items (zoomable + searchable) -->
            <DockPanel Grid.Column="2" Margin="4">

                <!-- Header -->
                <DockPanel DockPanel.Dock="Top" Margin="6,6,6,4">
                    <TextBlock x:Name="ZoomLabel"
                   DockPanel.Dock="Right" HorizontalAlignment="Right"
                   FontSize="11" Foreground="#52525b"
                   VerticalAlignment="Center"
                   Text="100%" Margin="8,0,0,0"/>
                    <TextBlock FontWeight="Bold" FontSize="12" Foreground="#71717a"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis">
            <Run Text="ITEMS — "/>
            <Run Text="{Binding ItemsHeader}"/>
                    </TextBlock>
                </DockPanel>

                <!-- Search bar -->
                <Border DockPanel.Dock="Top" Background="#1f1f23"
            BorderBrush="#3f3f46" BorderThickness="1"
            CornerRadius="4" Margin="6,0,6,6"
            Padding="4,0">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                    Content="✕" FontSize="12"
                    Command="{Binding ClearSearchCommand}"
                    Padding="6,2" Margin="4,0,0,0"
                    Visibility="{Binding SearchText.Length,
                        Converter={StaticResource BoolToVis}}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#71717a"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent" Padding="4,2">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="#dc2626"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <TextBlock DockPanel.Dock="Right"
                       Text="{Binding ItemCountText}"
                       FontSize="11" Foreground="#52525b"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"/>

                        <TextBlock DockPanel.Dock="Left"
                       Text="🔍" FontSize="12"
                       VerticalAlignment="Center"
                       Margin="4,0,6,0" Foreground="#52525b"/>

                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Background="Transparent"
                     Foreground="#f4f4f5"
                     BorderThickness="0"
                     FontSize="13"
                     VerticalAlignment="Center"
                     Padding="2,4"/>
                    </DockPanel>
                </Border>

                <!-- Diff grid (visible in diff mode) -->
                <DataGrid ItemsSource="{Binding DiffItems}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserSortColumns="True" SelectionMode="Single"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDiffMode}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Item" Width="*" MinWidth="160" SortMemberPath="Name">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="2,0">
                                        <Image DockPanel.Dock="Left" Width="24" Height="24"
                                               Margin="0,0,6,0" VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Source="{Binding Icon, Converter={StaticResource UrlToImage}}"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" Foreground="#f4f4f5"/>
                                    </DockPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Qty" Binding="{Binding QtyText}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#a1a1aa"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Change (div)" Width="100" SortMemberPath="ValueChangeDivine">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ValueChangeText}"
                                               VerticalAlignment="Center" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#4ade80"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGain}" Value="False">
                                                        <Setter Property="Foreground" Value="#ef4444"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Grid container — switches between priced and unpriced -->
                <Grid>
                    <!-- Priced items grid (visible when NOT showing unpriced AND NOT in diff mode) -->
                    <DataGrid x:Name="ItemsGrid"
                  ItemsSource="{Binding SelectedTabItems}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserSortColumns="True" SelectionMode="Single"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  EnableRowVirtualization="True"
                  PreviewMouseWheel="ItemsGrid_PreviewMouseWheel">

                        <DataGrid.Style>
                            <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsShowingUnpriced}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsDiffMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Style>

                        <DataGrid.LayoutTransform>
                            <ScaleTransform x:Name="GridScale" ScaleX="1" ScaleY="1"/>
                        </DataGrid.LayoutTransform>

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Item" Width="300"
                                        MinWidth="180" SortMemberPath="Name">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="2,0">
                                            <Image DockPanel.Dock="Left"
                                       Width="28" Height="28"
                                       Margin="0,0,8,0"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       VerticalAlignment="Center"
                                       Source="{Binding Icon,
                                           Converter={StaticResource UrlToImage}}"/>
                                            <TextBlock Text="{Binding Name}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="#f4f4f5"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Tab"
                                    Binding="{Binding TabName}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#71717a"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="7d" Width="110"
                                        CanUserSort="True"
                                        SortMemberPath="SparklineTrend">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="2,0">
                                            <Canvas Width="56" Height="18"
                                        VerticalAlignment="Center">
                                                <Polyline Points="{Binding SparklineData,
                                                  Converter={StaticResource SparklineToPoints}}"
                                              StrokeThickness="1.5"
                                              StrokeLineJoin="Round">
                                                    <Polyline.Style>
                                                        <Style TargetType="Polyline">
                                                            <Setter Property="Stroke" Value="#22c55e"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSparklineUp}"
                                                                 Value="False">
                                                                    <Setter Property="Stroke" Value="#ef4444"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Polyline.Style>
                                                </Polyline>
                                            </Canvas>
                                            <TextBlock VerticalAlignment="Center"
                                           FontSize="10" FontWeight="SemiBold"
                                           Margin="4,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding SparklineText}"/>
                                                        <Setter Property="Foreground" Value="#22c55e"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSparklineUp}"
                                                             Value="False">
                                                                <Setter Property="Foreground" Value="#ef4444"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding HasSparkline}"
                                                             Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Qty"
                                    Binding="{Binding Quantity}" Width="55">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#f4f4f5"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Unit"
                                    Binding="{Binding UnitDisplay}" Width="80"
                                    SortMemberPath="UnitPriceChaos">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#f4f4f5"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Total (c)"
                                    Binding="{Binding TotalPriceChaos, StringFormat=N1}"
                                    Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#f59e0b"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Total (div)"
                                    Binding="{Binding TotalPriceDivine, StringFormat=N2}"
                                    Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#b45309"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Unpriced items grid (visible when showing unpriced) -->
                    <DataGrid ItemsSource="{Binding UnpricedItems}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserSortColumns="True" SelectionMode="Single"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">

                        <DataGrid.Style>
                            <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsShowingUnpriced}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Style>

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Item" Width="*"
                                        MinWidth="200" SortMemberPath="Name">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="2,0">
                                            <Image DockPanel.Dock="Left"
                                       Width="28" Height="28"
                                       Margin="0,0,8,0"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       VerticalAlignment="Center"
                                       Source="{Binding Icon,
                                           Converter={StaticResource UrlToImage}}"/>
                                            <TextBlock Text="{Binding Name}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="#f4f4f5"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Category"
                                    Binding="{Binding Category}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#71717a"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Tab"
                                    Binding="{Binding TabName}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#71717a"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Qty"
                                    Binding="{Binding Quantity}" Width="55">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#f4f4f5"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </DockPanel>
            
            <GridSplitter Grid.Column="3" Width="4" Background="#27272a"/>

            <!-- Right: History -->
            <DockPanel Grid.Column="4" Margin="4">

                <DockPanel DockPanel.Dock="Top" Margin="6,6,6,4">
                    <Button DockPanel.Dock="Right" Content="🗑 Clear All"
                            Command="{Binding DeleteAllSnapshotsCommand}"
                            Padding="8,3" FontSize="11"
                            HorizontalAlignment="Right"/>
                    <TextBlock Text="WEALTH HISTORY"
                               FontWeight="Bold" FontSize="12" Foreground="#71717a"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <!-- Note editor (visible when a snapshot is selected) -->
                <Border DockPanel.Dock="Bottom" Margin="4,4,4,4" Padding="6,4"
                        Background="#1f1f23" BorderBrush="#3f3f46" BorderThickness="1"
                        CornerRadius="4"
                        Visibility="{Binding HasSelectedSnapshot, Converter={StaticResource BoolToVis}}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left" Text="📝" FontSize="11"
                                   Foreground="#52525b" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding EditingNote, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0" Padding="0"
                                 Foreground="#a1a1aa" FontSize="11"
                                 VerticalAlignment="Center"
                                 ToolTip="Add a note to this snapshot — saved automatically"/>
                    </DockPanel>
                </Border>

                <!-- Diff compare button (visible when a pin is set + snapshot selected) -->
                <Border DockPanel.Dock="Bottom" Margin="4,0,4,4"
                        Visibility="{Binding CanShowDiff, Converter={StaticResource BoolToVis}}">
                    <Button Command="{Binding ToggleDiffCommand}" Padding="8,3" FontSize="11">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Content" Value="↔ Show Diff"/>
                                <Setter Property="Background" Value="#1e3a2f"/>
                                <Setter Property="BorderBrush" Value="#4ade80"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDiffMode}" Value="True">
                                        <Setter Property="Content" Value="↔ Hide Diff"/>
                                        <Setter Property="Background" Value="#27272a"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Border>

                <ListBox ItemsSource="{Binding History}"
                         SelectedItem="{Binding SelectedSnapshot}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Style.Triggers>
                                <DataTrigger Value="True">
                                    <DataTrigger.Binding>
                                        <MultiBinding Converter="{StaticResource Equality}">
                                            <Binding Path="Id"/>
                                            <Binding Path="DataContext.PinnedSnapshotId"
                                                     RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        </MultiBinding>
                                    </DataTrigger.Binding>
                                    <Setter Property="BorderBrush" Value="#4ade80"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="Background" Value="#0d2119"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <Button x:Name="DeleteBtn"
                                        DockPanel.Dock="Right"
                                        Content="✕" Opacity="0"
                                        Style="{StaticResource DeleteXButton}"
                                        VerticalAlignment="Top"
                                        Margin="4,0,0,0"
                                        Command="{Binding DataContext.DeleteSnapshotCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Id}"/>
                                <Button x:Name="PinBtn"
                                        DockPanel.Dock="Right"
                                        Content="📌" Opacity="0"
                                        VerticalAlignment="Top"
                                        FontSize="11" Padding="4,0"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="#a1a1aa" Cursor="Hand"
                                        ToolTip="Pin as diff baseline"
                                        Command="{Binding DataContext.PinSnapshotCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"/>

                                <TextBlock x:Name="PctText"
                                           DockPanel.Dock="Right"
                                           Text="{Binding PercentChangeText}"
                                           FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Top"
                                           Margin="6,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#22c55e"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUp}" Value="False">
                                                    <Setter Property="Foreground" Value="#ef4444"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <StackPanel>
                                    <TextBlock Text="{Binding Display}" FontSize="11"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Note}" FontSize="10"
                                               Foreground="#52525b" TextTrimming="CharacterEllipsis"
                                               Margin="0,1,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Note}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver,
                                    RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                    Value="True">
                                    <Setter TargetName="DeleteBtn" Property="Opacity" Value="1"/>
                                    <Setter TargetName="PinBtn" Property="Opacity" Value="1"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>

        <!-- ═══ Row 6 — Status bar ═══ -->
        <Border Grid.Row="6" Background="#09090b" Padding="12,6"
        BorderBrush="#27272a" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock Text="{Binding StatusText}" FontSize="12"
                   Foreground="#a1a1aa"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentVersion}"
                       FontSize="11" Foreground="#52525b"
                       Margin="0,0,12,0"/>
                    <ProgressBar IsIndeterminate="{Binding IsBusy}"
                         Width="120" Height="4"
                         Background="#27272a" Foreground="#f59e0b"
                         />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>