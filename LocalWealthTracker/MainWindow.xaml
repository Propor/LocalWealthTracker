<Window x:Class="LocalWealthTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:LocalWealthTracker.Converters"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Local Wealth Tracker — Path of Exile"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2e" Foreground="#e0e0e0">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:UrlToImageConverter x:Key="UrlToImage"/>
        <converters:SparklineToPointsConverter x:Key="SparklineToPoints"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3a3a5c"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#555577"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4a4a6c"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Delete ✕ button -->
        <Style x:Key="DeleteXButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#cc4444"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#ff6666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#252540"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="RowBackground" Value="#252540"/>
            <Setter Property="AlternatingRowBackground" Value="#2a2a48"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#333355"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2e2e50"/>
            <Setter Property="Foreground" Value="#c0c0dd"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="6,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3a3a5c"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="36"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#252540"/>
            <Setter Property="BorderBrush" Value="#333355"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3a3a5c"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30304c"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Row 0 — Toolbar ═══ -->
        <Border Background="#252540" Padding="12,8"
                BorderBrush="#333355" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="📄 Export" Command="{Binding ExportCsvCommand}"
                            FontSize="13" Margin="0,0,6,0"
                            ToolTip="Export current view to CSV"/>
                    <Button Content="🔄 Refresh" Command="{Binding RefreshCommand}"
                            FontSize="14" Margin="0,0,6,0"
                            ToolTip="Fetch stash items and update prices"/>
                    <Button Content="⏹ Cancel" Command="{Binding RefreshCancelCommand}"
                            FontSize="14" Margin="0,0,12,0"/>
                    <Button Content="⚙ Settings" Command="{Binding OpenSettingsCommand}"
                            FontSize="14"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontSize="13" Foreground="#888" Margin="0,0,16,0">
                        <Run Text="League: "/>
                        <Run Text="{Binding LeagueDisplay}" Foreground="#c0c0dd"
                             FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Foreground="#888" Margin="0,0,16,0">
                        <Run Text="Synced tabs: "/>
                        <Run Text="{Binding SyncedTabCount}" Foreground="#c0c0dd"
                             FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Foreground="#666"
                               ToolTip="Items in your stash that couldn't be matched to a poe.ninja price">
                        <Run Text="Unpriced: "/>
                        <Run Text="{Binding UnpricedCount}" Foreground="#888"/>
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ Row 1 — Summary ═══ -->
        <Border Grid.Row="1" Background="#2a2a48" Padding="16,10"
                BorderBrush="#333355" BorderThickness="0,0,0,1">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock FontSize="22" FontWeight="Bold" Foreground="#f1c40f"
                           Margin="0,0,24,0"
                           ToolTip="Total wealth across all synced tabs">
                    <Run Text="{Binding TotalDivine, StringFormat='{}{0:N1}'}"/>
                    <Run Text=" divine" FontSize="14" Foreground="#c0a030"/>
                </TextBlock>
                <TextBlock FontSize="16" Foreground="#aaa" Margin="0,0,24,0"
                           ToolTip="Same value expressed in chaos orbs">
                    <Run Text="("/>
                    <Run Text="{Binding TotalChaos, StringFormat='{}{0:N0}'}"/>
                    <Run Text=" chaos)"/>
                </TextBlock>
                <TextBlock FontSize="13" Foreground="#888" Margin="0,0,24,0"
                           ToolTip="Current divine/chaos exchange rate from poe.ninja">
                    <Run Text="1 Divine = "/>
                    <Run Text="{Binding DivinePrice, StringFormat='{}{0:N0}'}"/>
                    <Run Text="c"/>
                </TextBlock>
                <TextBlock FontSize="13" Foreground="#888" Margin="0,0,24,0"
                           ToolTip="Number of items in the poe.ninja price database">
                    <Run Text="Prices: "/>
                    <Run Text="{Binding PriceEntries, StringFormat='{}{0:N0}'}"/>
                </TextBlock>
                <TextBlock FontSize="13" Foreground="#888"
                           ToolTip="Time of last successful refresh">
                    <Run Text="Last: "/>
                    <Run Text="{Binding LastRefresh}"/>
                </TextBlock>
            </WrapPanel>
        </Border>

        <!-- ═══ Row 2 — Main content ═══ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="300" MinWidth="250"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Stash tabs + Unpriced -->
            <DockPanel Margin="4">
                <TextBlock DockPanel.Dock="Top" Text="STASH TABS"
               FontWeight="Bold" FontSize="12" Foreground="#888"
               Margin="6,6,0,6"/>

                <!-- Unpriced items button — only visible when there are unpriced items -->
                <Border DockPanel.Dock="Bottom"
            Margin="0,4,0,0"
            Visibility="{Binding ShowUnpricedTab, Converter={StaticResource BoolToVis}}">
                    <Button Command="{Binding ShowUnpricedCommand}"
                HorizontalContentAlignment="Stretch"
                Padding="8,6">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#2a2030" BorderBrush="#553355"
                            BorderThickness="1" CornerRadius="4"
                            Padding="8,6" Cursor="Hand">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding UnpricedCount}"
                                       Foreground="#ef4444" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        <StackPanel>
                                            <TextBlock Text="⚠ Unpriced Items" FontWeight="SemiBold"
                                           Foreground="#ef4444"
                                           TextTrimming="CharacterEllipsis"/>
                                            <TextBlock FontSize="11" Foreground="#886666"
                                           TextTrimming="CharacterEllipsis">
                                    <Run Text="Items not found on poe.ninja"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>

                <ListBox ItemsSource="{Binding Tabs}"
             SelectedItem="{Binding SelectedTab}"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <Border DockPanel.Dock="Left" Width="8" Height="8"
                            CornerRadius="4" Margin="0,0,8,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding Color}"/>
                                    </Border.Background>
                                </Border>
                                <TextBlock DockPanel.Dock="Right"
                               Text="{Binding TotalDivine, StringFormat='{}{0:N1}d'}"
                               Foreground="#f1c40f" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Summary}" FontSize="11"
                                   Foreground="#888"
                                   TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" Background="#333355"/>

            <!-- Center: Items (zoomable + searchable) -->
            <DockPanel Grid.Column="2" Margin="4">

                <!-- Header -->
                <DockPanel DockPanel.Dock="Top" Margin="6,6,6,4">
                    <TextBlock x:Name="ZoomLabel"
                   DockPanel.Dock="Right" HorizontalAlignment="Right"
                   FontSize="11" Foreground="#666"
                   VerticalAlignment="Center"
                   Text="100%" Margin="8,0,0,0"/>
                    <TextBlock FontWeight="Bold" FontSize="12" Foreground="#888"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis">
            <Run Text="ITEMS — "/>
            <Run Text="{Binding ItemsHeader}"/>
                    </TextBlock>
                </DockPanel>

                <!-- Search bar -->
                <Border DockPanel.Dock="Top" Background="#2a2a3e"
            BorderBrush="#444466" BorderThickness="1"
            CornerRadius="4" Margin="6,0,6,6"
            Padding="4,0">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                    Content="✕" FontSize="12"
                    Command="{Binding ClearSearchCommand}"
                    Padding="6,2" Margin="4,0,0,0"
                    Visibility="{Binding SearchText.Length,
                        Converter={StaticResource BoolToVis}}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#888"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent" Padding="4,2">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="#cc4444"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <TextBlock DockPanel.Dock="Right"
                       Text="{Binding ItemCountText}"
                       FontSize="11" Foreground="#666"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"/>

                        <TextBlock DockPanel.Dock="Left"
                       Text="🔍" FontSize="12"
                       VerticalAlignment="Center"
                       Margin="4,0,6,0" Foreground="#666"/>

                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Background="Transparent"
                     Foreground="#e0e0e0"
                     BorderThickness="0"
                     FontSize="13"
                     VerticalAlignment="Center"
                     Padding="2,4"/>
                    </DockPanel>
                </Border>

                <!-- Grid container — switches between priced and unpriced -->
                <Grid>
                    <!-- Priced items grid (visible when NOT showing unpriced) -->
                    <DataGrid x:Name="ItemsGrid"
                  ItemsSource="{Binding SelectedTabItems}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserSortColumns="True" SelectionMode="Single"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  EnableRowVirtualization="True"
                  PreviewMouseWheel="ItemsGrid_PreviewMouseWheel">

                        <DataGrid.Style>
                            <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsShowingUnpriced}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Style>

                        <DataGrid.LayoutTransform>
                            <ScaleTransform x:Name="GridScale" ScaleX="1" ScaleY="1"/>
                        </DataGrid.LayoutTransform>

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Item" Width="300"
                                        MinWidth="180" SortMemberPath="Name">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="2,0">
                                            <Image DockPanel.Dock="Left"
                                       Width="28" Height="28"
                                       Margin="0,0,8,0"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       VerticalAlignment="Center"
                                       Source="{Binding Icon,
                                           Converter={StaticResource UrlToImage}}"/>
                                            <TextBlock Text="{Binding Name}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="#e0e0e0"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="7d" Width="110"
                                        CanUserSort="True"
                                        SortMemberPath="SparklineTrend">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="2,0">
                                            <Canvas Width="56" Height="18"
                                        VerticalAlignment="Center">
                                                <Polyline Points="{Binding SparklineData,
                                                  Converter={StaticResource SparklineToPoints}}"
                                              StrokeThickness="1.5"
                                              StrokeLineJoin="Round">
                                                    <Polyline.Style>
                                                        <Style TargetType="Polyline">
                                                            <Setter Property="Stroke" Value="#4ade80"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSparklineUp}"
                                                                 Value="False">
                                                                    <Setter Property="Stroke" Value="#ef4444"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Polyline.Style>
                                                </Polyline>
                                            </Canvas>
                                            <TextBlock VerticalAlignment="Center"
                                           FontSize="10" FontWeight="SemiBold"
                                           Margin="4,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding SparklineText}"/>
                                                        <Setter Property="Foreground" Value="#4ade80"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSparklineUp}"
                                                             Value="False">
                                                                <Setter Property="Foreground" Value="#ef4444"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding HasSparkline}"
                                                             Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Qty"
                                    Binding="{Binding Quantity}" Width="55">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#e0e0e0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Unit"
                                    Binding="{Binding UnitDisplay}" Width="80"
                                    SortMemberPath="UnitPriceChaos">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#e0e0e0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Total (c)"
                                    Binding="{Binding TotalPriceChaos, StringFormat=N1}"
                                    Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#f1c40f"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Total (div)"
                                    Binding="{Binding TotalPriceDivine, StringFormat=N2}"
                                    Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#c0a030"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Unpriced items grid (visible when showing unpriced) -->
                    <DataGrid ItemsSource="{Binding UnpricedItems}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserSortColumns="True" SelectionMode="Single"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">

                        <DataGrid.Style>
                            <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsShowingUnpriced}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Style>

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Item" Width="*"
                                        MinWidth="200" SortMemberPath="Name">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="2,0">
                                            <Image DockPanel.Dock="Left"
                                       Width="28" Height="28"
                                       Margin="0,0,8,0"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       VerticalAlignment="Center"
                                       Source="{Binding Icon,
                                           Converter={StaticResource UrlToImage}}"/>
                                            <TextBlock Text="{Binding Name}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="#e0e0e0"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Category"
                                    Binding="{Binding Category}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#888"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Tab"
                                    Binding="{Binding TabName}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#888"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Qty"
                                    Binding="{Binding Quantity}" Width="55">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#e0e0e0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </DockPanel>
            
            <GridSplitter Grid.Column="3" Width="4" Background="#333355"/>

            <!-- Right: Chart + History -->
            <DockPanel Grid.Column="4" Margin="4">

                <DockPanel DockPanel.Dock="Top" Margin="6,6,6,6">
                    <Button DockPanel.Dock="Right" Content="🗑 Clear All"
                            Command="{Binding DeleteAllSnapshotsCommand}"
                            Padding="8,3" FontSize="11"
                            HorizontalAlignment="Right"/>
                    <TextBlock Text="WEALTH HISTORY"
                               FontWeight="Bold" FontSize="12" Foreground="#888"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <Border DockPanel.Dock="Top" Background="#252540"
                        BorderBrush="#333355" BorderThickness="1"
                        CornerRadius="4" Height="200" Margin="0,0,0,8">
                    <lvc:CartesianChart
                        Series="{Binding ChartSeries}"
                        XAxes="{Binding ChartXAxes}"
                        YAxes="{Binding ChartYAxes}"
                        TooltipPosition="Hidden"
                        LegendPosition="Hidden"
                        AnimationsSpeed="00:00:00.300"/>
                </Border>

                <ListBox ItemsSource="{Binding History}"
                         SelectedItem="{Binding SelectedSnapshot}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <Button x:Name="DeleteBtn"
                                        DockPanel.Dock="Right"
                                        Content="✕" Opacity="0"
                                        Style="{StaticResource DeleteXButton}"
                                        VerticalAlignment="Center"
                                        Margin="4,0,0,0"
                                        Command="{Binding DataContext.DeleteSnapshotCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Id}"/>

                                <TextBlock x:Name="PctText"
                                           DockPanel.Dock="Right"
                                           Text="{Binding PercentChangeText}"
                                           FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4ade80"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUp}"
                                                             Value="False">
                                                    <Setter Property="Foreground"
                                                            Value="#ef4444"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Text="{Binding Display}" FontSize="11"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver,
                                    RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                    Value="True">
                                    <Setter TargetName="DeleteBtn"
                                            Property="Opacity" Value="1"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>

        <!-- ═══ Row 3 — Status bar ═══ -->
        <Border Grid.Row="3" Background="#1a1a2a" Padding="12,6"
                BorderBrush="#333355" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock Text="{Binding StatusText}" FontSize="12"
                           Foreground="#aaa"/>
                <ProgressBar IsIndeterminate="{Binding IsBusy}"
                             HorizontalAlignment="Right" Width="120" Height="4"
                             Background="#333355" Foreground="#f1c40f"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>