<Window x:Class="LocalWealthTracker.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings — Local Wealth Tracker"
        Width="600" Height="720"
        MinWidth="450" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e2e" Foreground="#e0e0e0"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#a0a0c0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2a2a3e"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3a3a5c"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#555577"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4a4a6c"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Row 0 — Connection ═══ -->
        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="CONNECTION" FontWeight="Bold" FontSize="12"
                       Foreground="#888" Margin="0,0,0,8"/>

            <Label Content="POESESSID:" Margin="0,0,0,2"/>
            <DockPanel Margin="0,0,0,4">
                <Button DockPanel.Dock="Right" Content="🗑 Delete"
                        Command="{Binding DeleteCredentialCommand}"
                        Padding="10,4" FontSize="12" Margin="8,0,0,0"
                        ToolTip="Delete stored POESESSID from disk"/>
                <PasswordBox x:Name="SessionBox"
                             PasswordChanged="SessionBox_PasswordChanged"
                             Background="#2a2a3e" Foreground="#e0e0e0"
                             BorderBrush="#444466" Padding="6,4" FontSize="13"/>
            </DockPanel>

            <!-- Security info -->
            <Border Background="#2a2a3e" CornerRadius="4" Padding="10,8"
                    Margin="0,0,0,10" BorderBrush="#444466" BorderThickness="1">
                <StackPanel>
                    <TextBlock FontSize="11" Foreground="#888" TextWrapping="Wrap">
                        <Run Text="🔒" FontSize="13"/>
                        <Run Text=" Your POESESSID is encrypted with Windows DPAPI and stored in"/>
                        <Run Text=" session.bin" FontWeight="SemiBold" Foreground="#aaa"/>
                        <Run Text=". Only your Windows user on this machine can decrypt it."/>
                        <Run Text=" It is NEVER sent anywhere except pathofexile.com."/>
                    </TextBlock>
                    <TextBlock FontSize="11" Margin="0,4,0,0"
                               Visibility="{Binding HasStoredCredential, Converter={StaticResource BoolToVis}}">
                        <Run Text="✅ " Foreground="#4ade80"/>
                        <Run Text="Encrypted credential stored." Foreground="#4ade80"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Label Content="League:" Margin="0,0,0,2"/>
            <TextBox Text="{Binding League, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,4"/>
        </StackPanel>

        <!-- ═══ Row 1 — General ═══ -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="GENERAL" FontWeight="Bold" FontSize="12"
               Foreground="#888" Margin="0,0,0,8"/>
            <WrapPanel>
                <StackPanel Margin="0,0,24,0">
                    <Label Content="Min item value (chaos):" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding MinItemValue, UpdateSourceTrigger=PropertyChanged}"
                     Width="80" HorizontalAlignment="Left"/>
                </StackPanel>
                <StackPanel Margin="0,0,24,0">
                    <Label Content="Auto-refresh (minutes, 0 = off):" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding AutoRefreshMinutes, UpdateSourceTrigger=PropertyChanged}"
                     Width="80" HorizontalAlignment="Left"/>
                </StackPanel>
                <StackPanel>
                    <Label Content="Price cache (minutes):" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding PriceCacheMinutes, UpdateSourceTrigger=PropertyChanged}"
                     Width="80" HorizontalAlignment="Left"
                     ToolTip="How long to reuse cached prices before fetching fresh ones from poe.ninja. Default: 10 min."/>
                </StackPanel>
            </WrapPanel>
        </StackPanel>

        <!-- ═══ Row 2 — Stash tab header ═══ -->
        <DockPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock DockPanel.Dock="Left" Text="STASH TABS"
                       FontWeight="Bold" FontSize="12" Foreground="#888"
                       VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Select All" Command="{Binding SelectAllCommand}"
                        Padding="10,4" FontSize="12" Margin="0,0,4,0"/>
                <Button Content="Select None" Command="{Binding SelectNoneCommand}"
                        Padding="10,4" FontSize="12" Margin="0,0,8,0"/>
                <Button Content="📡 Fetch Stashes" Command="{Binding FetchStashesCommand}"
                        FontSize="13"/>
            </StackPanel>
        </DockPanel>

        <!-- ═══ Row 3 — Stash tab list ═══ -->
        <Border Grid.Row="3" Background="#252540" BorderBrush="#333355"
                BorderThickness="1" CornerRadius="4" Margin="0,0,0,12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Tabs}" Margin="4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" Margin="0,1"
                                    CornerRadius="3" Background="#2a2a48">
                                <DockPanel>
                                    <CheckBox DockPanel.Dock="Left"
                                              IsChecked="{Binding IsSynced}"
                                              Margin="0,0,10,0"
                                              VerticalAlignment="Center"/>
                                    <Border DockPanel.Dock="Left"
                                            Width="10" Height="10"
                                            CornerRadius="5"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding Color}"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding Type}"
                                               Foreground="#666" FontSize="11"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ═══ Row 4 — Status + buttons ═══ -->
        <DockPanel Grid.Row="4">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Content="💾 Save" Command="{Binding SaveCommand}"
                        FontSize="14" Margin="0,0,8,0"/>
                <Button Content="Close" Click="CloseButton_Click"
                        FontSize="14"/>
            </StackPanel>
            <TextBlock Text="{Binding StatusText}" FontSize="12"
                       Foreground="#aaa" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
            <ProgressBar IsIndeterminate="{Binding IsBusy}"
                         Width="100" Height="4"
                         Background="#333355" Foreground="#f1c40f"
                         VerticalAlignment="Center"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
        </DockPanel>
    </Grid>
</Window>