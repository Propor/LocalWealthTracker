<Window x:Class="LocalWealthTracker.ModifierProfilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modifier Profiles — Local Wealth Tracker"
        Width="1020" Height="760"
        MinWidth="720" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        Background="#09090b" Foreground="#f4f4f5">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="5"
                      GlassFrameThickness="0" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="TitleBarCloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a1a1aa"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#c0392b"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#f4f4f5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1f1f23"/>
            <Setter Property="Foreground" Value="#f4f4f5"/>
            <Setter Property="BorderBrush" Value="#3f3f46"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="CaretBrush" Value="#f4f4f5"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1f1f23"/>
            <Setter Property="Foreground" Value="#f4f4f5"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3f3f46"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#27272a"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1f1f23"/>
            <Setter Property="Foreground" Value="#f4f4f5"/>
            <Setter Property="BorderBrush" Value="#3f3f46"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="#3f3f46" BorderThickness="1"
                                                CornerRadius="4">
                                            <DockPanel>
                                                <Path DockPanel.Dock="Right"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#71717a" VerticalAlignment="Center"
                                                      Margin="0,0,8,0"/>
                                                <ContentPresenter/>
                                            </DockPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#27272a"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ToggleButton.Background>
                                    <SolidColorBrush Color="#1f1f23"/>
                                </ToggleButton.Background>
                            </ToggleButton>
                            <!-- Non-editable: show selected item text -->
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False"
                                              Margin="10,5,28,5"
                                              VerticalAlignment="Center"/>
                            <!-- Editable: text input box (required part name for WPF) -->
                            <TextBox x:Name="PART_EditableTextBox"
                                     Background="Transparent"
                                     Foreground="#f4f4f5"
                                     CaretBrush="#f4f4f5"
                                     BorderThickness="0"
                                     Margin="8,0,26,0"
                                     VerticalAlignment="Center"
                                     Focusable="True"
                                     Visibility="Collapsed"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#1f1f23" BorderBrush="#3f3f46"
                                            BorderThickness="1" CornerRadius="0,0,4,4">
                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#27272a"/>
            <Setter Property="Foreground" Value="#f4f4f5"/>
            <Setter Property="BorderBrush" Value="#3f3f46"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3f3f46"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#18181b"/>
            <Setter Property="BorderBrush" Value="#27272a"/>
            <Setter Property="Foreground" Value="#f4f4f5"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#27272a"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3f3f46"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Focusable="False" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3f3f46" CornerRadius="3" Margin="1,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Focusable="False" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Title bar -->
        <Border DockPanel.Dock="Top" Background="#111113" Height="36">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="✕" Style="{StaticResource TitleBarCloseButton}"
                            Click="CloseButton_Click"/>
                </StackPanel>
                <TextBlock Text="Modifier Profiles" VerticalAlignment="Center"
                           Margin="14,0" FontSize="12" Foreground="#52525b"/>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#111113" Padding="14,8"
                BorderBrush="#27272a" BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="💾 Save &amp; Close" Click="SaveClose_Click"
                            Background="#14532d" BorderBrush="#22c55e"
                            Padding="16,6" FontSize="13"/>
                </StackPanel>
                <TextBlock x:Name="StatusText"
                           Text="Changes are saved when you click Save &amp; Close."
                           FontSize="11" Foreground="#52525b" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Main: profile list (left) | editor (right) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: profiles panel -->
            <Border Background="#18181b" BorderBrush="#27272a" BorderThickness="0,0,1,0">
                <DockPanel Margin="14,16,14,14">
                    <!-- Header with accent strip -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                        <Border DockPanel.Dock="Left" Width="3" Background="#a78bfa"
                                CornerRadius="2" Margin="0,1,8,1"/>
                        <TextBlock Text="PROFILES" FontWeight="SemiBold" FontSize="11"
                                   Foreground="#a78bfa" VerticalAlignment="Center"/>
                    </DockPanel>
                    <!-- Add/Delete buttons -->
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="+ Add" Click="AddProfile_Click"
                                Padding="12,5" FontSize="12" Margin="0,0,8,0"/>
                        <Button x:Name="DeleteBtn" Content="🗑 Delete" Click="DeleteProfile_Click"
                                Padding="10,5" FontSize="12" IsEnabled="False"/>
                    </StackPanel>
                    <!-- Profile list -->
                    <ListBox x:Name="ProfileList"
                             SelectionChanged="ProfileList_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             DisplayMemberPath="Name"
                             Background="Transparent" BorderBrush="Transparent"/>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="#27272a"/>

            <!-- Right: editor -->
            <Grid Grid.Column="2" Margin="16,14,14,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- row 0: dummy EditorPanel -->
                    <RowDefinition Height="Auto"/>   <!-- row 1: name card -->
                    <RowDefinition Height="12"/>     <!-- row 2: spacer -->
                    <RowDefinition Height="*"/>      <!-- row 3: find & add card -->
                    <RowDefinition Height="12"/>     <!-- row 4: spacer -->
                    <RowDefinition Height="196"/>    <!-- row 5: profile mods card -->
                </Grid.RowDefinitions>

                <!-- No-selection placeholder -->
                <TextBlock x:Name="NoSelectionHint" Grid.RowSpan="6"
                           Text="Select a profile on the left, or click + Add to create one."
                           Foreground="#52525b" FontSize="13" TextWrapping="Wrap"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Margin="24" Panel.ZIndex="1"/>

                <!-- Dummy: controls visibility of editor rows via binding -->
                <StackPanel x:Name="EditorPanel" Grid.Row="0" Visibility="Collapsed"/>

                <!-- Name card -->
                <Border Grid.Row="1"
                        Background="#18181b" BorderBrush="#27272a" BorderThickness="1"
                        CornerRadius="6" Padding="14,10"
                        Visibility="{Binding Visibility, ElementName=EditorPanel}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left" Text="Profile name:"
                                   Foreground="#71717a" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,12,0" Width="86"/>
                        <TextBox x:Name="NameBox" TextChanged="NameBox_TextChanged" FontSize="13"/>
                    </DockPanel>
                </Border>

                <!-- Find & Add Modifiers card -->
                <Border Grid.Row="3"
                        Background="#18181b" BorderBrush="#27272a" BorderThickness="1"
                        CornerRadius="6"
                        Visibility="{Binding Visibility, ElementName=EditorPanel}">
                    <Grid Margin="16,14,16,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>   <!-- header -->
                            <RowDefinition Height="Auto"/>   <!-- separator -->
                            <RowDefinition Height="Auto"/>   <!-- modifier type label -->
                            <RowDefinition Height="6"/>      <!-- gap -->
                            <RowDefinition Height="Auto"/>   <!-- category + search row -->
                            <RowDefinition Height="14"/>     <!-- gap -->
                            <RowDefinition Height="Auto"/>   <!-- base type label -->
                            <RowDefinition Height="6"/>      <!-- gap -->
                            <RowDefinition Height="Auto"/>   <!-- base type row -->
                            <RowDefinition Height="Auto"/>   <!-- status -->
                            <RowDefinition Height="Auto"/>   <!-- results separator -->
                            <RowDefinition Height="*"/>      <!-- results list -->
                        </Grid.RowDefinitions>

                        <!-- Header row -->
                        <DockPanel Grid.Row="0" Margin="0,0,0,12">
                            <Border DockPanel.Dock="Left" Width="3" Background="#a78bfa"
                                    CornerRadius="2" Margin="0,2,8,2"/>
                            <Button DockPanel.Dock="Right" Content="↺ Refresh"
                                    Click="RefreshMods_Click"
                                    Padding="8,3" FontSize="11"
                                    Background="Transparent" BorderBrush="Transparent"
                                    Foreground="#52525b"
                                    ToolTip="Force re-fetch modifier list from pathofexile.com trade API"/>
                            <TextBlock Text="FIND &amp; ADD MODIFIERS"
                                       FontWeight="SemiBold" FontSize="11" Foreground="#a78bfa"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <!-- Separator -->
                        <Rectangle Grid.Row="1" Height="1" Fill="#27272a" Margin="0,0,0,16"/>

                        <!-- Modifier type label -->
                        <TextBlock Grid.Row="2" Text="Modifier type &amp; search"
                                   FontSize="11" Foreground="#71717a"/>

                        <!-- Category + search row -->
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="CategoryCombo" SelectionChanged="Filter_Changed"/>
                            <TextBox Grid.Column="2" x:Name="SearchBox"
                                     TextChanged="SearchBox_TextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Margin="10,0,0,0" Text="Search modifiers…"
                                                                           Foreground="#52525b" FontSize="13"
                                                                           FontFamily="Segoe UI"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>

                        <!-- Base type label -->
                        <TextBlock Grid.Row="6" Text="Base type filter"
                                   FontSize="11" Foreground="#71717a"/>

                        <!-- Base type row -->
                        <Grid Grid.Row="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="BaseGroupCombo" Grid.Column="0"
                                      SelectionChanged="BaseGroupCombo_Changed"/>
                            <ComboBox x:Name="BaseTypeCombo" Grid.Column="2"
                                      SelectionChanged="BaseTypeCombo_Changed"
                                      IsEditable="True" IsTextSearchEnabled="True"
                                      StaysOpenOnEdit="True"/>
                        </Grid>

                        <!-- Status / loading / count -->
                        <StackPanel Grid.Row="9" Margin="0,10,0,0">
                            <StackPanel x:Name="LoadingRow" Orientation="Horizontal">
                                <TextBlock x:Name="LoadingText" Text="⏳ Loading modifier list…"
                                           FontSize="11" Foreground="#71717a"/>
                            </StackPanel>
                            <TextBlock x:Name="ErrorText" FontSize="11" Foreground="#ef4444"
                                       TextWrapping="Wrap" Visibility="Collapsed"/>
                            <TextBlock x:Name="ResultCountText" FontSize="11" Foreground="#52525b"
                                       Visibility="Collapsed"/>
                        </StackPanel>

                        <!-- Divider before results -->
                        <Rectangle Grid.Row="10" Height="1" Fill="#27272a" Margin="0,10,0,0"/>

                        <!-- Results list -->
                        <ListBox x:Name="ModResultsList" Grid.Row="11"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Background="Transparent" BorderBrush="Transparent"
                                 Margin="0,6,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,1">
                                        <Button DockPanel.Dock="Right" Content="+"
                                                FontSize="15" FontWeight="Bold"
                                                Padding="6,0" Width="30"
                                                Click="AddMod_Click"
                                                ToolTip="Add to profile"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="#4ade80"/>
                                        <Border DockPanel.Dock="Right"
                                                Background="#1c1c20" BorderBrush="#3f3f46"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="5,2" Margin="4,0,6,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding GroupLabel}"
                                                       FontSize="10" Foreground="#71717a"/>
                                        </Border>
                                        <TextBlock Text="{Binding Text}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontSize="12" Foreground="#d4d4d8"
                                                   ToolTip="{Binding Text}"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Profile Modifiers card -->
                <Border Grid.Row="5"
                        Background="#18181b" BorderBrush="#27272a" BorderThickness="1"
                        CornerRadius="6"
                        Visibility="{Binding Visibility, ElementName=EditorPanel}">
                    <Grid Margin="14,12,14,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>   <!-- header -->
                            <RowDefinition Height="Auto"/>   <!-- separator -->
                            <RowDefinition Height="*"/>      <!-- mods list -->
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <Border DockPanel.Dock="Left" Width="3" Background="#a78bfa"
                                    CornerRadius="2" Margin="0,2,8,2"/>
                            <TextBlock x:Name="ProfileModsHeader"
                                       Text="PROFILE MODIFIERS (0)"
                                       FontWeight="SemiBold" FontSize="11" Foreground="#a78bfa"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <!-- Separator -->
                        <Rectangle Grid.Row="1" Height="1" Fill="#27272a" Margin="0,0,0,10"/>

                        <!-- Mods list -->
                        <ListBox x:Name="ProfileModsList" Grid.Row="2"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Background="Transparent" BorderBrush="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,1">
                                        <Button DockPanel.Dock="Right" Content="✕"
                                                FontSize="12" Padding="4,0" Width="24"
                                                Click="RemoveMod_Click"
                                                ToolTip="Remove from profile"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="#ef4444"/>
                                        <Border DockPanel.Dock="Left"
                                                Background="#1c2a3a" BorderBrush="#3b82f6"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="5,2" Margin="0,0,8,0"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasBaseConstraint}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding BadgeText}"
                                                       FontSize="10" Foreground="#93c5fd"/>
                                        </Border>
                                        <TextBlock Text="{Binding ModText}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontSize="12" Foreground="#f4f4f5"
                                                   ToolTip="{Binding DisplayText}"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
