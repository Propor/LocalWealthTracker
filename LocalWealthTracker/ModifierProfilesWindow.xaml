<Window x:Class="LocalWealthTracker.ModifierProfilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modifier Profiles — Local Wealth Tracker"
        Width="640" Height="480"
        MinWidth="480" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize"
        Background="#09090b" Foreground="#f4f4f5">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="5"
                      GlassFrameThickness="0" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="TitleBarCloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a1a1aa"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#c0392b"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#f4f4f5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1f1f23"/>
            <Setter Property="Foreground" Value="#f4f4f5"/>
            <Setter Property="BorderBrush" Value="#3f3f46"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="CaretBrush" Value="#f4f4f5"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#27272a"/>
            <Setter Property="Foreground" Value="#f4f4f5"/>
            <Setter Property="BorderBrush" Value="#3f3f46"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3f3f46"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#18181b"/>
            <Setter Property="BorderBrush" Value="#27272a"/>
            <Setter Property="Foreground" Value="#f4f4f5"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#27272a"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3f3f46"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Focusable="False" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3f3f46" CornerRadius="3" Margin="1,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Focusable="False" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Title bar -->
        <Border DockPanel.Dock="Top" Background="#111113" Height="32">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="✕" Style="{StaticResource TitleBarCloseButton}"
                            Click="CloseButton_Click"/>
                </StackPanel>
                <TextBlock Text="Modifier Profiles" VerticalAlignment="Center"
                           Margin="12,0" FontSize="12" Foreground="#52525b"/>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#111113" Padding="12,6"
                BorderBrush="#27272a" BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="💾 Save &amp; Close" Click="SaveClose_Click"
                            Background="#14532d" BorderBrush="#22c55e"
                            Padding="14,5" FontSize="13"/>
                </StackPanel>
                <TextBlock x:Name="StatusText" Text="Changes are saved when you click Save &amp; Close."
                           FontSize="11" Foreground="#52525b" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Main: profiles list (left) + editor (right) -->
        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: profile list + add/delete -->
            <DockPanel Margin="12,12,0,12">
                <TextBlock DockPanel.Dock="Top" Text="PROFILES"
                           FontWeight="Bold" FontSize="11" Foreground="#71717a"
                           Margin="0,0,0,6"/>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="+ Add" Click="AddProfile_Click"
                            Padding="10,4" FontSize="12" Margin="0,0,6,0"/>
                    <Button x:Name="DeleteBtn" Content="🗑 Delete" Click="DeleteProfile_Click"
                            Padding="10,4" FontSize="12" IsEnabled="False"/>
                </StackPanel>

                <ListBox x:Name="ProfileList"
                         SelectionChanged="ProfileList_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" Background="#27272a"/>

            <!-- Right: profile editor -->
            <DockPanel Grid.Column="2" Margin="12,12,12,12">
                <TextBlock DockPanel.Dock="Top" Text="PROFILE EDITOR"
                           FontWeight="Bold" FontSize="11" Foreground="#71717a"
                           Margin="0,0,0,6"/>

                <!-- Placeholder when nothing selected -->
                <TextBlock x:Name="NoSelectionHint"
                           Text="Select a profile on the left, or click + Add to create one."
                           Foreground="#52525b" FontSize="12"
                           TextWrapping="Wrap" VerticalAlignment="Center"
                           HorizontalAlignment="Center" Margin="16"/>

                <!-- Editor panel (hidden when no profile selected) -->
                <StackPanel x:Name="EditorPanel" Visibility="Collapsed">
                    <TextBlock Text="Profile name:" Foreground="#a1a1aa" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="NameBox" Margin="0,0,0,12"
                             TextChanged="NameBox_TextChanged"/>

                    <TextBlock Foreground="#a1a1aa" FontSize="12" Margin="0,0,0,4">
                        <Run Text="Modifier strings "/>
                        <Run Text="(one per line — partial, case-insensitive match):"
                             Foreground="#52525b"/>
                    </TextBlock>
                    <TextBox x:Name="ModsBox"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             Height="250"
                             VerticalContentAlignment="Top"
                             FontFamily="Consolas"
                             FontSize="12"
                             TextChanged="ModsBox_TextChanged"/>
                    <TextBlock Foreground="#52525b" FontSize="11" Margin="0,4,0,0"
                               TextWrapping="Wrap">
                        Example: enter <Run Text="nearby enemies are" FontStyle="Italic" Foreground="#71717a"/>
                        to match any mod containing that text.
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
